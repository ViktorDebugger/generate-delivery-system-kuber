# Скопіюй у delivery-secrets.local.yaml, заміни CHANGE_* / postgres пароль / JWT, не коміть результат.
# Або створи Secret через kubectl — k8s/README.md
apiVersion: v1
kind: Secret
metadata:
  name: delivery-secrets
  namespace: delivery
type: Opaque
stringData:
  catalog-database-url: postgresql://postgres:CHANGE_ME_DB_PASSWORD@postgres:5432/catalog?schema=public
  fleet-database-url: postgresql://postgres:CHANGE_ME_DB_PASSWORD@postgres:5432/fleet?schema=public
  orders-database-url: postgresql://postgres:CHANGE_ME_DB_PASSWORD@postgres:5432/orders?schema=public
  jwt-secret: CHANGE_ME_MIN_32_CHAR_JWT_SECRET_VALUE
