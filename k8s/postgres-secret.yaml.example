# Скопіюй у postgres-credentials.local.yaml і підстав пароль, або:
# kubectl create secret generic postgres-credentials -n delivery \
#   --from-literal=POSTGRES_USER=postgres \
#   --from-literal=POSTGRES_PASSWORD=YOUR_PASSWORD \
#   --from-literal=POSTGRES_DB=postgres
#
# Той самий пароль має бути в delivery-secrets (catalog-database-url тощо).
apiVersion: v1
kind: Secret
metadata:
  name: postgres-credentials
  namespace: delivery
type: Opaque
stringData:
  POSTGRES_USER: postgres
  POSTGRES_PASSWORD: CHANGE_ME_DB_PASSWORD
  POSTGRES_DB: postgres
