generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id          String    @id @default(uuid())
  name        String
  description String?
  products    Product[]
}

model Product {
  id         String    @id @default(uuid())
  name       String
  price      Decimal   @db.Decimal(12, 2)
  categoryId String?   @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id])
}
